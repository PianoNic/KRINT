# Copy to .env and fill in. docker compose loads this file into the keycloak and krint services.
# DB credentials and connection strings are hardcoded in compose.yml, so no need to set them here.

# ---------- Keycloak ----------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Public hostname Keycloak issues tokens for. Local dev: localhost.
KC_HOSTNAME=localhost
KC_HTTP_ENABLED=true
KC_PROXY_HEADERS=xforwarded

# ---------- KRINT API ----------
# Which database KRINT stores its own data in: "Sqlite" (default) or "Postgres".
# Sqlite needs no extra service - the connection string defaults to "Data Source=krint.db".
# For Postgres, set the provider and a Npgsql connection string (compose.yml does this for the
# bundled stack). Example:
#   Database__Provider=Postgres
#   ConnectionStrings__KrintDatabase=Host=db;Port=5432;Database=krint;Username=postgres;Password=...
Database__Provider=Sqlite
# ConnectionStrings__KrintDatabase=Data Source=/data/krint.db

# Master key used to encrypt secrets at rest. Generate with: openssl rand -base64 32
Vault__MasterKey=change-me

# OIDC settings. Authority points at the Keycloak realm; redirect URIs must match the client
# config in keycloak/krint-realm.json.
Oidc__Authority=http://localhost:8080/realms/krint
Oidc__ClientId=krint
Oidc__RedirectUri=http://localhost:4200/
Oidc__PostLogoutRedirectUri=http://localhost:4200/
Oidc__Scope=openid profile email roles
Oidc__RequireHttpsMetadata=false

# Origin(s) allowed to call the API from the browser. Add more as Cors__AllowedOrigins__1, __2, ...
Cors__AllowedOrigins__0=http://localhost:4200
