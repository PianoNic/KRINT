            "family_name": "User",
            "preferred_username": "testuser",
            "email": "test@example.com",
            "email_verified": true,
            "picture": "https://i.pravatar.cc/150?img=57",
            "roles": ["admin"]
          }
        }
      ]
    }
  ]
}
