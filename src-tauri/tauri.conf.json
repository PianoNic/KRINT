{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KRINT",
  "version": "0.1.0",
  "identifier": "app.krint.desktop",
  "build": {
    "beforeBuildCommand": "node scripts/publish-sidecar.mjs",
    "frontendDist": "loading"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/PianoNic/KRINT/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_OUTPUT_OF__npx_tauri_signer_generate"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KRINT",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/krint-api"],
    "resources": ["resources/krint.yaml", "resources/wwwroot/**/*"]
  }
}
